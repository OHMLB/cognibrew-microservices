# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false                     # false = start RabbitMQ consumer; true = skip consumer (local dev only)
DEVICE_ID=edge-device-01        # unique ID of this edge device

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_INFERENCE_EXCHANGE_NAME=cognibrew.inference
RABBITMQ_RECOMMENDATION_QUEUE_NAME=cognibrew.inference.face_recognized
RABBITMQ_FACE_RECOGNIZED_ROUTING_KEY=face.recognized

# ── Catalog Service ───────────────────────────────────────────────────────────
CATALOG_SERVICE_URL=http://catalog-service:8000
CATALOG_RECOMMENDATION_LIMIT=5
CATALOG_HTTP_TIMEOUT=10.0

# ── HTTP API ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX_STR=/api/v1
