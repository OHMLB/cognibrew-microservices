# ── App ───────────────────────────────────────────────────────────────────────
PROJECT_NAME=CogniBrew Cloud API Gateway
ENVIRONMENT=production          # local | staging | production
DEBUG=false
LOG_LEVEL=INFO
API_PREFIX_STR=/api/v1

# ── Downstream Services ───────────────────────────────────────────────────────
CATALOG_SERVICE_URL=http://catalog-service:8000
FEEDBACK_SERVICE_URL=http://feedback-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000

# ── HTTP Client ───────────────────────────────────────────────────────────────
HTTP_TIMEOUT=30.0
