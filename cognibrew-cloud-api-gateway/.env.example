# ── App ───────────────────────────────────────────────────────────────────────
PROJECT_NAME=CogniBrew Cloud API Gateway
ENVIRONMENT=production          # local | staging | production
DEBUG=false
LOG_LEVEL=INFO
API_PREFIX_STR=/api/v1

# ── Downstream Services ───────────────────────────────────────────────────────
CATALOG_SERVICE_URL=http://catalog-service:8000
FEEDBACK_SERVICE_URL=http://feedback-service:8080
NOTIFICATION_SERVICE_URL=http://notification-service:8080
USER_MANAGEMENT_SERVICE_URL=http://user-management-service:5001

# ── JWT (must match User Management Service) ──────────────────────────────────
JWT_SECRET_
JWT_ISSUER=semls-app-group
JWT_AUDIENCE=semls-app-audience
JWT_ALGORITHMS=HS256

# ── HTTP Client ───────────────────────────────────────────────────────────────
HTTP_TIMEOUT=30.0
